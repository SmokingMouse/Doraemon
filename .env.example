TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ALLOWED_USERS=123456789,987654321

# Proxy settings (optional, for users in China or behind firewall)
# Examples:
# TELEGRAM_PROXY_URL=socks5://127.0.0.1:1080
# TELEGRAM_PROXY_URL=http://127.0.0.1:7890
TELEGRAM_PROXY_URL=

# Timeout settings (optional, in seconds)
TELEGRAM_READ_TIMEOUT=30
TELEGRAM_WRITE_TIMEOUT=30
TELEGRAM_CONNECT_TIMEOUT=10

CLAUDE_CODE_PATH=claude

DATABASE_PATH=./data/doraemon.db

# Web settings
WEB_HOST=0.0.0.0
WEB_PORT=8765
WEB_SECRET_KEY=your-secret-key-change-me-in-production
WEB_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend settings
FRONTEND_PORT=5173
